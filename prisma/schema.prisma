generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ThemePreference {
  system
  light
  dark

  @@map("theme_preference")
}

enum GroupRole {
  owner
  admin
  moderator
  member

  @@map("group_role")
}

enum GroupChatChannelVisibility {
  public
  private

  @@map("group_chat_channel_visibility")
}

enum GroupChatChannelMessagePolicy {
  everyone
  admins

  @@map("group_chat_channel_message_policy")
}

enum MessageRequestStatus {
  pending
  accepted
  declined

  @@map("message_request_status")
}

enum FollowRequestStatus {
  pending
  accepted
  declined

  @@map("follow_request_status")
}

enum NotificationType {
  login
  salute
  comment
  reply
  mention
  follow
  follow_request
  message_request
  message_reaction
  group_join
  group_post
  repost
  repost_like

  @@map("notification_type")
}

enum GroupVisibility {
  public
  private

  @@map("group_visibility")
}

enum UserGender {
  female
  male
  non_binary
  prefer_not_to_say
  other

  @@map("user_gender")
}

enum ActivityPersona {
  runner
  bodybuilder
  cyclist
  yogi
  swimmer
  powerlifter
  crossfitter
  walker
  hiker
  climber
  martial_artist
  dancer
  pilates
  calisthenics
  rower
  triathlete
  soccer_player
  basketball_player
  other

  @@map("activity_persona")
}

enum BuddyActivity {
  running
  gym
  cycling
  yoga
  walking
  swimming
  hiking
  climbing
  martial_arts
  dance
  pilates
  calisthenics
  rowing
  triathlon
  soccer
  basketball
  sports
  other

  @@map("buddy_activity")
}

enum BuddySessionScope {
  public
  group

  @@map("buddy_session_scope")
}

enum BuddySessionVisibility {
  public
  private

  @@map("buddy_session_visibility")
}

enum PostReportReason {
  spam
  harassment
  nudity
  violence
  other

  @@map("post_report_reason")
}

enum UserReportReason {
  spam
  harassment
  nudity
  violence
  other

  @@map("user_report_reason")
}

enum PostVisibility {
  public
  followers
  mutuals
  close_buddies
  only_me

  @@map("post_visibility")
}

enum ProfileVisibility {
  public
  followers
  mutuals
  close_buddies
  private

  @@map("profile_visibility")
}

enum IntegrationProvider {
  strava
  garmin

  @@map("integration_provider")
}

enum IntegrationStatus {
  connected
  disconnected
  revoked
  error

  @@map("integration_status")
}

enum ActivitySource {
  manual
  strava
  garmin

  @@map("activity_source")
}

model User {
  id                    String            @id @default(uuid())
  email                 String            @unique
  passwordHash          String            @map("password_hash")
  displayName           String?           @map("display_name")
  username              String            @unique
  usernameFinalized     Boolean           @default(true) @map("username_finalized")
  bio                   String?
  profileImageUrl       String?           @map("profile_image_url")
  coverImageUrl         String?           @map("cover_image_url")
  gender                UserGender?       @map("gender")
  dateOfBirth           DateTime?         @map("date_of_birth")
  profileVisibility     ProfileVisibility @default(public) @map("profile_visibility")
  defaultPostVisibility PostVisibility    @default(public) @map("default_post_visibility")
  betaUser              Boolean           @default(false) @map("beta_user")
  hideProfileBadges     Boolean           @default(false) @map("hide_profile_badges")
  hiddenProfileBadgeCodes String[]         @default([]) @map("hidden_profile_badge_codes")
  verified              Boolean           @default(false)
  googleId              String?           @unique @map("google_id")
  googleEmailVerified   Boolean           @default(false) @map("google_email_verified")
  legalConsentAt        DateTime?         @map("legal_consent_at")
  dataConsentAt         DateTime?         @map("data_consent_at")
  chatPublicKey         String?           @map("chat_public_key")
  chatPrivateKey        String?           @map("chat_private_key")
  latitude              Float?
  longitude             Float?
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  posts                     Post[]
  wallPosts                 Post[]                   @relation("ProfileWallPosts")
  taggedPosts               PostTag[]                @relation("PostTaggedUsers")
  comments                  Comment[]
  likes                     PostLike[]
  commentLikes              CommentLike[]
  savedPosts                PostSave[]
  viewedPosts               PostView[]
  reposts                   Repost[]
  repostLikes               RepostLike[]
  hiddenPosts               HiddenPost[]
  postReports               PostReport[]
  userReportsSent           UserReport[]             @relation("UserReportsSent")
  userReportsReceived       UserReport[]             @relation("UserReportsReceived")
  blocksSent                Block[]                  @relation("BlocksSent")
  blocksReceived            Block[]                  @relation("BlocksReceived")
  notifications             Notification[]           @relation("NotificationsReceived")
  notificationActors        Notification[]           @relation("NotificationActors")
  theme                     UserTheme?
  refreshTokens             RefreshToken[]
  passwordResetTokens       PasswordResetToken[]
  following                 Follow[]                 @relation("Following")
  followers                 Follow[]                 @relation("Followers")
  sentFollowRequests        FollowRequest[]          @relation("SentFollowRequests")
  receivedFollowRequests    FollowRequest[]          @relation("ReceivedFollowRequests")
  sentMessageRequests       MessageRequest[]         @relation("SentMessageRequests")
  receivedMessageRequests   MessageRequest[]         @relation("ReceivedMessageRequests")
  chatProfileOverrides      ChatProfileOverride[]    @relation("ChatProfileOverrideOwners")
  chatProfileOverridePeers  ChatProfileOverride[]    @relation("ChatProfileOverridePeers")
  groupMembers              GroupMember[]
  createdBuddyGroupChats    BuddyGroupChat[]         @relation("BuddyGroupChatCreators")
  buddyGroupChatMemberships BuddyGroupChatMember[]
  createdGroupChannels      GroupChatChannel[]       @relation("GroupChatChannelCreators")
  groupChannelMemberships   GroupChatChannelMember[]
  groupPosts                GroupPost[]
  sentMessages              Message[]                @relation("SentMessages")
  receivedMessages          Message[]                @relation("ReceivedMessages")
  buddySession              BuddySession?
  createdBuddyRooms         BuddyRoom[]              @relation("BuddyRoomCreators")
  closeBuddies              CloseBuddy[]             @relation("CloseBuddyOwners")
  closeBuddyOf              CloseBuddy[]             @relation("CloseBuddyMembers")
  externalIntegrations      ExternalIntegration[]
  activities                Activity[]
  activityPersonas          UserActivityPersona[]
  stories                   Story[]
  storyViews                StoryView[]
  storyReactions            StoryReaction[]
  badges                    UserBadge[]

  @@index([latitude, longitude])
  @@index([createdAt])
  @@map("users")
}

model Badge {
  id          String      @id @default(uuid())
  code        String      @unique
  label       String
  description String?
  iconUrl     String      @map("icon_url")
  sortOrder   Int         @default(0) @map("sort_order")
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  users       UserBadge[]

  @@index([active, sortOrder])
  @@map("badges")
}

model UserBadge {
  userId     String   @map("user_id")
  badgeId    String   @map("badge_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by")
  note       String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@index([badgeId])
  @@index([userId, assignedAt])
  @@map("user_badges")
}

model UserActivityPersona {
  userId    String          @map("user_id")
  persona   ActivityPersona
  sortOrder Int             @default(0) @map("sort_order")
  createdAt DateTime        @default(now()) @map("created_at")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, persona])
  @@index([persona])
  @@index([userId, sortOrder])
  @@map("user_activity_personas")
}

model BuddySession {
  id          String         @id @default(uuid())
  userId      String         @unique @map("user_id")
  roomId      String?        @map("room_id")
  activity    BuddyActivity?
  subActivity String?        @map("sub_activity")
  latitude    Float
  longitude   Float
  expiresAt   DateTime       @map("expires_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  room        BuddyRoom?     @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([roomId, expiresAt])
  @@index([activity, expiresAt])
  @@index([latitude, longitude])
  @@map("buddy_sessions")
}

model BuddyRoom {
  id          String                 @id @default(uuid())
  name        String
  scope       BuddySessionScope      @default(public)
  visibility  BuddySessionVisibility @default(public)
  code        String                 @unique
  groupId     String?                @map("group_id")
  creatorId   String                 @map("creator_id")
  activity    BuddyActivity?
  subActivity String?                @map("sub_activity")
  expiresAt   DateTime               @map("expires_at")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  group       Group?                 @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator     User                   @relation("BuddyRoomCreators", fields: [creatorId], references: [id], onDelete: Cascade)
  sessions    BuddySession[]

  @@index([scope, visibility, expiresAt])
  @@index([groupId, expiresAt])
  @@map("buddy_rooms")
}

model Follow {
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

model FollowRequest {
  id          String              @id @default(uuid())
  requesterId String              @map("requester_id")
  recipientId String              @map("recipient_id")
  status      FollowRequestStatus @default(pending)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  requester   User                @relation("SentFollowRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient   User                @relation("ReceivedFollowRequests", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([recipientId, status, createdAt])
  @@index([requesterId, status, createdAt])
  @@map("follow_requests")
}

model MessageRequest {
  id                  String               @id @default(uuid())
  senderId            String               @map("sender_id")
  recipientId         String               @map("recipient_id")
  body                String
  referenceType       String?              @map("reference_type")
  referenceId         String?              @map("reference_id")
  referenceMediaUrl   String?              @map("reference_media_url")
  referenceText       String?              @map("reference_text")
  referenceAuthorName String?              @map("reference_author_name")
  status              MessageRequestStatus @default(pending)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  sender              User                 @relation("SentMessageRequests", fields: [senderId], references: [id], onDelete: Cascade)
  recipient           User                 @relation("ReceivedMessageRequests", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, status, createdAt])
  @@index([senderId, status, createdAt])
  @@map("message_requests")
}

model ChatProfileOverride {
  id              String   @id @default(uuid())
  ownerId         String   @map("owner_id")
  peerId          String   @map("peer_id")
  displayName     String?  @map("display_name")
  profileImageUrl String?  @map("profile_image_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  owner           User     @relation("ChatProfileOverrideOwners", fields: [ownerId], references: [id], onDelete: Cascade)
  peer            User     @relation("ChatProfileOverridePeers", fields: [peerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, peerId])
  @@index([peerId])
  @@map("chat_profile_overrides")
}

model UserTheme {
  userId    String          @id @map("user_id")
  theme     ThemePreference @default(system)
  updatedAt DateTime        @updatedAt @map("updated_at")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_themes")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, revokedAt, expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, usedAt, expiresAt])
  @@map("password_reset_tokens")
}

model Post {
  id             String         @id @default(uuid())
  authorId       String         @map("author_id")
  profileOwnerId String?        @map("profile_owner_id")
  groupId        String?        @map("group_id")
  text           String?
  latitude       Float?
  longitude      Float?
  viewCount      Int            @default(0) @map("view_count")
  likeCount      Int            @default(0) @map("like_count")
  commentCount   Int            @default(0) @map("comment_count")
  pinnedAt       DateTime?      @map("pinned_at")
  visibility     PostVisibility @default(public)
  isAnonymous    Boolean        @default(false) @map("is_anonymous")
  activityId     String?        @map("activity_id")
  editedAt       DateTime?      @map("edited_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  author       User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  profileOwner User?             @relation("ProfileWallPosts", fields: [profileOwnerId], references: [id], onDelete: Cascade)
  group        Group?            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  images       PostImage[]
  hashtags     PostHashtag[]
  likes        PostLike[]
  saves        PostSave[]
  views        PostView[]
  reposts      Repost[]
  reports      PostReport[]
  hiddenBy     HiddenPost[]
  comments     Comment[]
  editHistory  PostEditHistory[]
  taggedUsers  PostTag[]
  activity     Activity?         @relation(fields: [activityId], references: [id])

  @@index([authorId, createdAt])
  @@index([profileOwnerId, createdAt])
  @@index([groupId, createdAt])
  @@index([activityId])
  @@index([visibility, createdAt])
  @@index([createdAt])
  @@index([latitude, longitude])
  @@map("posts")
}

model PostImage {
  id        String  @id @default(uuid())
  postId    String  @map("post_id")
  url       String
  alt       String?
  mediaType String  @default("image") @map("media_type")
  mimeType  String? @map("mime_type")
  filename  String?
  size      Int?
  width     Int?
  height    Int?
  sortOrder Int     @default(0) @map("sort_order")
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, sortOrder])
  @@map("post_images")
}

model Story {
  id            String          @id @default(uuid())
  authorId      String          @map("author_id")
  text          String?
  mediaUrl      String?         @map("media_url")
  mediaType     String?         @map("media_type")
  mimeType      String?         @map("mime_type")
  filename      String?
  textPlacement String          @default("caption") @map("text_placement")
  visibility    PostVisibility  @default(public)
  viewCount     Int             @default(0) @map("view_count")
  expiresAt     DateTime        @map("expires_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  author        User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views         StoryView[]
  reactions     StoryReaction[]

  @@index([authorId, createdAt])
  @@index([expiresAt, createdAt])
  @@index([visibility, expiresAt, createdAt])
  @@map("stories")
}

model StoryView {
  storyId  String   @map("story_id")
  userId   String   @map("user_id")
  viewedAt DateTime @default(now()) @map("viewed_at")
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storyId, userId])
  @@index([userId, viewedAt])
  @@map("story_views")
}

model StoryReaction {
  storyId   String   @map("story_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([storyId, userId])
  @@index([storyId, emoji])
  @@index([userId, updatedAt])
  @@map("story_reactions")
}

model Hashtag {
  id    String        @id @default(uuid())
  name  String        @unique
  posts PostHashtag[]

  @@map("hashtags")
}

model PostHashtag {
  postId    String  @map("post_id")
  hashtagId String  @map("hashtag_id")
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  hashtag   Hashtag @relation(fields: [hashtagId], references: [id], onDelete: Cascade)

  @@id([postId, hashtagId])
  @@index([hashtagId])
  @@map("post_hashtags")
}

model PostTag {
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation("PostTaggedUsers", fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId, createdAt])
  @@map("post_tagged_users")
}

model PostLike {
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@map("post_likes")
}

model Comment {
  id          String               @id @default(uuid())
  postId      String               @map("post_id")
  authorId    String               @map("author_id")
  parentId    String?              @map("parent_id")
  body        String
  likeCount   Int                  @default(0) @map("like_count")
  editedAt    DateTime?            @map("edited_at")
  createdAt   DateTime             @default(now()) @map("created_at")
  post        Post                 @relation(fields: [postId], references: [id], onDelete: Cascade)
  author      User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent      Comment?             @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]            @relation("CommentReplies")
  likes       CommentLike[]
  images      CommentImage[]
  editHistory CommentEditHistory[]

  @@index([postId, createdAt])
  @@index([parentId, createdAt])
  @@map("comments")
}

model Group {
  id                  String             @id @default(uuid())
  name                String
  slug                String             @unique
  description         String?
  profileImageUrl     String?            @map("profile_image_url")
  coverImageUrl       String?            @map("cover_image_url")
  visibility          GroupVisibility    @default(public)
  inviteCode          String?            @unique @map("invite_code")
  allowAnonymousPosts Boolean            @default(false) @map("allow_anonymous_posts")
  createdAt           DateTime           @default(now()) @map("created_at")
  members             GroupMember[]
  chatChannels        GroupChatChannel[]
  messages            Message[]
  posts               Post[]
  legacyPosts         GroupPost[]
  buddyRooms          BuddyRoom[]

  @@index([visibility, createdAt])
  @@map("groups")
}

model GroupMember {
  groupId  String    @map("group_id")
  userId   String    @map("user_id")
  role     GroupRole @default(member)
  joinedAt DateTime  @default(now()) @map("joined_at")
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId, joinedAt])
  @@map("group_members")
}

model GroupChatChannel {
  id            String                        @id @default(uuid())
  groupId       String                        @map("group_id")
  creatorId     String                        @map("creator_id")
  name          String
  description   String?
  visibility    GroupChatChannelVisibility    @default(public)
  messagePolicy GroupChatChannelMessagePolicy @default(everyone) @map("message_policy")
  createdAt     DateTime                      @default(now()) @map("created_at")
  group         Group                         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator       User                          @relation("GroupChatChannelCreators", fields: [creatorId], references: [id], onDelete: Cascade)
  allowedUsers  GroupChatChannelMember[]
  messages      Message[]

  @@unique([groupId, name])
  @@index([groupId, createdAt])
  @@map("group_chat_channels")
}

model BuddyGroupChat {
  id          String                 @id @default(uuid())
  creatorId   String                 @map("creator_id")
  name        String
  description String?
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  creator     User                   @relation("BuddyGroupChatCreators", fields: [creatorId], references: [id], onDelete: Cascade)
  members     BuddyGroupChatMember[]
  messages    Message[]

  @@index([creatorId, createdAt])
  @@map("buddy_group_chats")
}

model BuddyGroupChatMember {
  buddyGroupChatId String         @map("buddy_group_chat_id")
  userId           String         @map("user_id")
  addedById        String?        @map("added_by_id")
  joinedAt         DateTime       @default(now()) @map("joined_at")
  buddyGroupChat   BuddyGroupChat @relation(fields: [buddyGroupChatId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([buddyGroupChatId, userId])
  @@index([userId, joinedAt])
  @@map("buddy_group_chat_members")
}

model GroupChatChannelMember {
  channelId String           @map("channel_id")
  userId    String           @map("user_id")
  createdAt DateTime         @default(now()) @map("created_at")
  channel   GroupChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@index([userId])
  @@map("group_chat_channel_members")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@unique([messageId, userId])
  @@index([messageId])
  @@map("message_reactions")
}

model Message {
  id                  String            @id @default(uuid())
  senderId            String            @map("sender_id")
  recipientId         String?           @map("recipient_id")
  groupId             String?           @map("group_id")
  buddyGroupChatId    String?           @map("buddy_group_chat_id")
  channelId           String?           @map("channel_id")
  body                String
  referenceType       String?           @map("reference_type")
  referenceId         String?           @map("reference_id")
  referenceMediaUrl   String?           @map("reference_media_url")
  referenceText       String?           @map("reference_text")
  referenceAuthorName String?           @map("reference_author_name")
  ciphertext          String?
  nonce               String?
  encrypted           Boolean           @default(false)
  readAt              DateTime?         @map("read_at")
  deletedAt           DateTime?         @map("deleted_at")
  deletedById         String?           @map("deleted_by_id")
  createdAt           DateTime          @default(now()) @map("created_at")
  sender              User              @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient           User?             @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  group               Group?            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  buddyGroupChat      BuddyGroupChat?   @relation(fields: [buddyGroupChatId], references: [id], onDelete: Cascade)
  channel             GroupChatChannel? @relation(fields: [channelId], references: [id], onDelete: Cascade)
  reactions           MessageReaction[]

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, senderId, createdAt])
  @@index([recipientId, senderId, readAt])
  @@index([recipientId, readAt])
  @@index([groupId, createdAt])
  @@index([buddyGroupChatId, createdAt])
  @@index([channelId, createdAt])
  @@map("messages")
}

model CommentImage {
  id        String   @id @default(uuid())
  commentId String   @map("comment_id")
  url       String
  alt       String?
  filename  String?
  mimeType  String?  @map("mime_type")
  size      Int?
  width     Int?
  height    Int?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@map("comment_images")
}

model PostEditHistory {
  id        String   @id @default(uuid())
  postId    String   @map("post_id")
  editorId  String   @map("editor_id")
  oldText   String?  @map("old_text")
  newText   String?  @map("new_text")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("post_edit_history")
}

model CommentEditHistory {
  id        String   @id @default(uuid())
  commentId String   @map("comment_id")
  editorId  String   @map("editor_id")
  oldBody   String   @map("old_body")
  newBody   String   @map("new_body")
  createdAt DateTime @default(now()) @map("created_at")
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId, createdAt])
  @@map("comment_edit_history")
}

model CommentLike {
  commentId String   @map("comment_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([userId, createdAt])
  @@map("comment_likes")
}

model PostSave {
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId, createdAt])
  @@map("post_saves")
}

model PostView {
  postId        String   @map("post_id")
  userId        String   @map("user_id")
  count         Int      @default(1)
  firstViewedAt DateTime @default(now()) @map("first_viewed_at")
  lastViewedAt  DateTime @updatedAt @map("last_viewed_at")
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId, lastViewedAt])
  @@map("post_views")
}

model Repost {
  id        String       @id @default(uuid())
  postId    String       @map("post_id")
  userId    String       @map("user_id")
  text      String?
  likeCount Int          @default(0) @map("like_count")
  createdAt DateTime     @default(now()) @map("created_at")
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     RepostLike[]

  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@map("reposts")
}

model RepostLike {
  repostId  String   @map("repost_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  repost    Repost   @relation(fields: [repostId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([repostId, userId])
  @@index([userId, createdAt])
  @@map("repost_likes")
}

model HiddenPost {
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId, createdAt])
  @@map("hidden_posts")
}

model PostReport {
  id        String           @id @default(uuid())
  postId    String           @map("post_id")
  userId    String           @map("user_id")
  reason    PostReportReason @default(other)
  note      String?
  createdAt DateTime         @default(now()) @map("created_at")
  post      Post             @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, createdAt])
  @@index([userId, createdAt])
  @@map("post_reports")
}

model UserReport {
  id         String           @id @default(uuid())
  reportedId String           @map("reported_id")
  reporterId String           @map("reporter_id")
  reason     UserReportReason @default(other)
  note       String?
  createdAt  DateTime         @default(now()) @map("created_at")
  reported   User             @relation("UserReportsReceived", fields: [reportedId], references: [id], onDelete: Cascade)
  reporter   User             @relation("UserReportsSent", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reportedId, reporterId])
  @@index([reportedId, createdAt])
  @@index([reporterId, createdAt])
  @@map("user_reports")
}

model Block {
  blockerId String   @map("blocker_id")
  blockedId String   @map("blocked_id")
  createdAt DateTime @default(now()) @map("created_at")
  blocker   User     @relation("BlocksSent", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  actorId   String?          @map("actor_id")
  type      NotificationType
  entityId  String?          @map("entity_id")
  message   String
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  user      User             @relation("NotificationsReceived", fields: [userId], references: [id], onDelete: Cascade)
  actor     User?            @relation("NotificationActors", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model GroupPost {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  authorId  String   @map("author_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
  @@index([authorId, createdAt])
  @@map("group_posts")
}

model CloseBuddy {
  ownerId   String   @map("owner_id")
  buddyId   String   @map("buddy_id")
  createdAt DateTime @default(now()) @map("created_at")
  owner     User     @relation("CloseBuddyOwners", fields: [ownerId], references: [id], onDelete: Cascade)
  buddy     User     @relation("CloseBuddyMembers", fields: [buddyId], references: [id], onDelete: Cascade)

  @@id([ownerId, buddyId])
  @@index([buddyId])
  @@map("close_buddies")
}

model ExternalIntegration {
  id               String              @id @default(uuid())
  userId           String              @map("user_id")
  provider         IntegrationProvider
  providerUserId   String?             @map("provider_user_id")
  status           IntegrationStatus   @default(connected)
  accessTokenHash  String?             @map("access_token_hash")
  refreshTokenHash String?             @map("refresh_token_hash")
  tokenExpiresAt   DateTime?           @map("token_expires_at")
  scopes           String[]            @default([])
  lastSyncAt       DateTime?           @map("last_sync_at")
  lastSyncError    String?             @map("last_sync_error")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities       Activity[]

  @@unique([userId, provider])
  @@index([provider, providerUserId])
  @@index([userId, status])
  @@map("external_integrations")
}

model Activity {
  id                    String               @id @default(uuid())
  userId                String               @map("user_id")
  integrationId         String?              @map("integration_id")
  source                ActivitySource       @default(manual)
  externalId            String?              @map("external_id")
  type                  String
  title                 String?
  startedAt             DateTime             @map("started_at")
  durationSeconds       Int?                 @map("duration_seconds")
  distanceMeters        Float?               @map("distance_meters")
  elevationGainMeters   Float?               @map("elevation_gain_meters")
  calories              Int?
  averageHeartRate      Int?                 @map("average_heart_rate")
  maxHeartRate          Int?                 @map("max_heart_rate")
  averagePaceSecondsKm  Int?                 @map("average_pace_seconds_km")
  averageSpeedMetersSec Float?               @map("average_speed_meters_sec")
  raw                   Json?
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  integration           ExternalIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  posts                 Post[]

  @@unique([source, externalId, userId])
  @@index([userId, startedAt])
  @@index([type, startedAt])
  @@map("activities")
}
