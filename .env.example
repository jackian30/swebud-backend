# Local Docker default:
DATABASE_URL="postgresql://swebud:swebud@localhost:55432/swebud?schema=public"
# Render + Supabase Free Postgres example. Keep low connection limits on the shared pooler.
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require&connection_limit=3"
# DIRECT_URL is required for Prisma migrations on Render/Supabase. Prefer direct DB when it is reachable over IPv4; otherwise use Supabase session pooler, not transaction pooler.
# DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
# DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require&connection_limit=1"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-too"
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
FRONTEND_ORIGIN="http://localhost:9000"
ADMIN_ORIGIN="http://localhost:9100"
ALLOW_LOCAL_ORIGINS=true
NATIVE_AUTH_ENABLED=false
NATIVE_APP_ORIGIN="https://localhost"
PORT=3000
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_IGNORE_TLS=true
SMTP_REQUIRE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="SweBudd <no-reply@localhost>"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:9000/auth/google/callback"
# Required and fail-closed in production; may remain empty only in local development.
CLOUDFLARE_TURNSTILE_SECRET_KEY=""

# Production subdomain layout example:
# FRONTEND_ORIGIN="https://swebudd.com"
# ADMIN_ORIGIN="" # Keep empty until an admin site has a public HTTPS origin.
# GOOGLE_CALLBACK_URL="https://api.swebudd.com/auth/google/callback"
# GOOGLE_OAUTH_REDIRECT_URI="https://swebudd.com/auth/google/callback"
KLIPY_API_KEY=""
KLIPY_CLIENT_KEY="swebud-local"
MEDIA_STORAGE_DRIVER="local"
# For S3 media storage:
# MEDIA_STORAGE_DRIVER="s3"
# MEDIA_S3_BUCKET=""
# MEDIA_PUBLIC_BASE_URL="https://cdn.example.com/"
# AWS_REGION="us-east-1"
# AWS_S3_ENDPOINT=""
# AWS_S3_FORCE_PATH_STYLE="false"
# Supabase Storage S3 example:
# MEDIA_STORAGE_DRIVER="s3"
# MEDIA_S3_BUCKET="swebudd-media"
# MEDIA_PUBLIC_BASE_URL="https://<project-ref>.supabase.co/storage/v1/object/public/swebudd-media/"
# AWS_REGION="ap-southeast-1"
# AWS_S3_ENDPOINT="https://<project-ref>.supabase.co/storage/v1/s3"
# AWS_S3_FORCE_PATH_STYLE="true"
# AWS_ACCESS_KEY_ID="<supabase-storage-access-key>"
# AWS_SECRET_ACCESS_KEY="<supabase-storage-secret-key>"
# Cloudflare R2 example:
# MEDIA_STORAGE_DRIVER="s3"
# MEDIA_S3_BUCKET="<bucket-name>"
# MEDIA_PUBLIC_BASE_URL="https://media.your-domain.com/"
# AWS_REGION="auto"
# AWS_S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# AWS_S3_FORCE_PATH_STYLE="true"
# AWS_ACCESS_KEY_ID="<r2-access-key-id>"
# AWS_SECRET_ACCESS_KEY="<r2-secret-access-key>"
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
STRAVA_WEBHOOK_VERIFY_TOKEN=""
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
