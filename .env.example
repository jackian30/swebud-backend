# Local Docker default:
DATABASE_URL="postgresql://swebud:swebud@localhost:5432/swebud?schema=public"
# Render + Supabase Free Postgres example:
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-too"
FRONTEND_ORIGIN="http://localhost:9000"
ADMIN_ORIGIN="http://localhost:9100"
ALLOW_LOCAL_ORIGINS=true
PORT=3000
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_IGNORE_TLS=true
SMTP_REQUIRE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="SweBudd <no-reply@localhost>"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:9000/auth/google/callback"
CLOUDFLARE_TURNSTILE_SITE_KEY=""
CLOUDFLARE_TURNSTILE_SECRET_KEY=""

# Production subdomain layout example:
# FRONTEND_ORIGIN="https://asdasd.com"
# Cloudflare Pages + Render example:
# FRONTEND_ORIGIN="https://swebud.pages.dev"
# ADMIN_ORIGIN="https://admin.asdasd.com"
# GOOGLE_CALLBACK_URL="https://api.asdasd.com/auth/google/callback"
# GOOGLE_OAUTH_REDIRECT_URI="https://asdasd.com/auth/google/callback"
KLIPY_API_KEY=""
KLIPY_CLIENT_KEY="swebud-local"
APP_VERSION="0.2.1-beta"
LEGAL_TERMS_URL=""
LEGAL_PRIVACY_URL=""
MEDIA_STORAGE_DRIVER="local"
# For S3 media storage:
# MEDIA_STORAGE_DRIVER="s3"
# MEDIA_S3_BUCKET=""
# MEDIA_PUBLIC_BASE_URL="https://cdn.example.com/"
# AWS_REGION="us-east-1"
# AWS_S3_ENDPOINT=""
# AWS_S3_FORCE_PATH_STYLE="false"
# Supabase Storage S3 example:
# MEDIA_STORAGE_DRIVER="s3"
# MEDIA_S3_BUCKET="<bucket-name>"
# MEDIA_PUBLIC_BASE_URL="https://<project-ref>.supabase.co/storage/v1/object/public/<bucket-name>/"
# AWS_REGION="ap-southeast-1"
# AWS_S3_ENDPOINT="https://<project-ref>.supabase.co/storage/v1/s3"
# AWS_S3_FORCE_PATH_STYLE="true"
# AWS_ACCESS_KEY_ID="<supabase-storage-access-key>"
# AWS_SECRET_ACCESS_KEY="<supabase-storage-secret-key>"
# Cloudflare R2 example:
# MEDIA_STORAGE_DRIVER="s3"
# MEDIA_S3_BUCKET="<bucket-name>"
# MEDIA_PUBLIC_BASE_URL="https://media.your-domain.com/"
# AWS_REGION="auto"
# AWS_S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# AWS_S3_FORCE_PATH_STYLE="true"
# AWS_ACCESS_KEY_ID="<r2-access-key-id>"
# AWS_SECRET_ACCESS_KEY="<r2-secret-access-key>"
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
STRAVA_WEBHOOK_VERIFY_TOKEN=""
GARMIN_CONSUMER_KEY=""
GARMIN_CONSUMER_SECRET=""
