POSTGRES_DB=swebud
POSTGRES_USER=swebud
POSTGRES_PASSWORD=
DATABASE_URL=
# Required for Prisma migrate deploy when production DATABASE_URL uses a pooler.
DIRECT_URL=
SWEBUD_NETWORK=swebud
SWEBUD_MODE=dev
# deploy.sh sets these to the current host IDs when omitted.
LOCAL_UID=
LOCAL_GID=
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
FRONTEND_ORIGIN=http://localhost:9000
ADMIN_ORIGIN=http://localhost:9100
ALLOW_LOCAL_ORIGINS=true
# Enable only for the signed Capacitor app transport.
NATIVE_AUTH_ENABLED=false
NATIVE_APP_ORIGIN=https://localhost
LEGACY_NATIVE_AUTH_COMPAT_UNTIL=
LEGACY_WEB_AUTH_COMPAT_UNTIL=
BACKEND_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=55432
BACKEND_PORT=3002
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_IGNORE_TLS=true
SMTP_REQUIRE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_IP_FAMILY=4
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_USER=
SMTP_PASS=
MAIL_FROM=SweBudd <no-reply@localhost>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3002/auth/google/callback
# Required and fail-closed when SWEBUD_MODE=prod; may remain empty for local dev.
CLOUDFLARE_TURNSTILE_SECRET_KEY=
KLIPY_API_KEY=
KLIPY_CLIENT_KEY=swebud-local
MEDIA_STORAGE_DRIVER=local
# For S3 media storage:
# MEDIA_STORAGE_DRIVER=s3
# MEDIA_S3_BUCKET=swebudd-media
# MEDIA_PUBLIC_BASE_URL=https://<project-ref>.supabase.co/storage/v1/object/public/swebudd-media/
# AWS_REGION=ap-southeast-1
# AWS_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
# AWS_S3_FORCE_PATH_STYLE=false
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=
GARMIN_CONSUMER_KEY=
GARMIN_CONSUMER_SECRET=
MAILHOG_SMTP_PORT=1126
MAILHOG_UI_PORT=8126
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:9000/auth/google/callback

# Production subdomain layout example:
# FRONTEND_ORIGIN=https://swebudd.com
# ADMIN_ORIGIN= # Keep empty until an admin site has a public HTTPS origin.
# GOOGLE_CALLBACK_URL=https://api.swebudd.com/auth/google/callback
# GOOGLE_OAUTH_REDIRECT_URI=https://swebudd.com/auth/google/callback
# Production mode refuses known/default secrets, local origins, MailHog, and
# plaintext SMTP. Set a real SMTP host, verified MAIL_FROM, TLS options, and
# distinct random JWT secrets before running `SWEBUD_MODE=prod deploy.sh`.
