FROM node:22-alpine

ARG LOCAL_UID=1000
ARG LOCAL_GID=1000

RUN apk add --no-cache ffmpeg

WORKDIR /app
RUN mkdir -p /app/node_modules \
    && chown -R "${LOCAL_UID}:${LOCAL_GID}" /app

# Match the host developer so build artifacts written through the bind mount
# are never owned by root. HOME points at a writable, disposable location for
# npm's cache even when the numeric host user has no container passwd entry.
ENV HOME=/tmp
USER ${LOCAL_UID}:${LOCAL_GID}
