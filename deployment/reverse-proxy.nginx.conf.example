# Example host-level nginx reverse proxy for:
# - portal: https://asdasd.com
# - API:    https://api.asdasd.com
#
# Replace domain names and certificate paths before using.

server {
  listen 80;
  server_name asdasd.com api.asdasd.com;
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl http2;
  server_name asdasd.com;

  ssl_certificate /etc/letsencrypt/live/asdasd.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/asdasd.com/privkey.pem;

  client_max_body_size 110m;

  location / {
    proxy_pass http://127.0.0.1:9000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}

server {
  listen 443 ssl http2;
  server_name api.asdasd.com;

  ssl_certificate /etc/letsencrypt/live/api.asdasd.com/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/api.asdasd.com/privkey.pem;

  client_max_body_size 110m;

  location /socket.io/ {
    proxy_pass http://127.0.0.1:3002;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }

  location / {
    proxy_pass http://127.0.0.1:3002;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
  }
}
